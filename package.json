{
  "name": "yipet",
  "version": "1.1.2",
  "private": true,
  "description": "Chrome 浏览器扩展，在网页中注入温柔陪伴伴侣。支持 AI 聊天、会话管理、FAQ 管理、Mermaid 图表渲染。",
  "author": "Chengliang Yi",
  "license": "MIT",
  "engines": {
    "node": ">=25"
  },
  "keywords": [
    "chrome-extension",
    "companion",
    "ai-chat",
    "pet",
    "mermaid"
  ],
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ignore-pattern node_modules --ignore-pattern .claude",
    "lint:fix": "eslint . --fix --ignore-pattern node_modules --ignore-pattern .claude",
    "format": "prettier --check '**/*.{js,mjs,json,css,html}'",
    "format:fix": "prettier --write '**/*.{js,mjs,json,css,html}'",
    "check": "npm run lint -- --max-warnings=0 && npm run format && npm test && npm run build",
    "clean": "rm -rf coverage test-results",
    "version": "node scripts/sync-version.mjs",
    "version:patch": "node scripts/sync-version.mjs patch",
    "version:minor": "node scripts/sync-version.mjs minor",
    "version:major": "node scripts/sync-version.mjs major",
    "build": "node scripts/build.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs}": [
      "eslint --fix --ignore-pattern node_modules --ignore-pattern .claude",
      "prettier --write"
    ],
    "*.{json,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^17.0.7",
    "node-fetch": "^3.3.2",
    "prettier": "^3.8.4",
    "vitest": "^3.1.1"
  }
}
